{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "bdd-build",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"dependsOn": [
				"eslint: lint",
				"tsc: build",
				"bddgen"
			],
			"dependsOrder": "sequence",
			"detail": "Runs tsc type-check, linting, and bddgen"
		},
		{
			"label": "eslint: lint",
			"group": "test",
			"type": "shell",
			"command": "npx",
			"args": [
				"eslint",
				"./tests",
				"--ext",
				".ts,.tsx,.mts,.cts",
				"--format",
				"stylish"
			],
			"detail": "Runs eslint on ./src/ and ./tests/",
			"problemMatcher": [
				"$eslint-stylish"
			],
			"presentation": {
				"panel": "shared",
				"clear": true,
				"focus": true,
				"revealProblems": "onProblem",
				"showReuseMessage": false
			},
		},
		{
			"label": "tsc: build",
			"group": "build",
			"type": "typescript",
			"tsconfig": "tsconfig.json",
			"detail": "Runs typescript compiler",
			"problemMatcher": [
				"$tsc"
			],
			"presentation": {
				"panel": "shared",
				"clear": true,
				"focus": true,
				"revealProblems": "onProblem",
				"showReuseMessage": false
			}
		},
		{
			"label": "bddgen",
			"group": "build",
			"type": "shell",
			"command": "npx",
			"args": [
				"bddgen"
			],
			"detail": "Runs playwright-bdd code generator",
			"presentation": {
				"panel": "shared",
				"clear": true,
				"focus": true,
				"revealProblems": "onProblem",
				"showReuseMessage": false
			}
		},
	]
}