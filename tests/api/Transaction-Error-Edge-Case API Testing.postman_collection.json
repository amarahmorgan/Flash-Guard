      "name": "03-Transactions",
      "item": [
        {
          "name": "POST-valid-transfer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"TC01 - Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC01 - Valid transfer is created as pending\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.expect(jsonData).to.have.property(\"id\");\r",
                  "    pm.expect(jsonData.sender_account_id).to.eql(Number(pm.environment.get(\"accountId\")));\r",
                  "    pm.expect(jsonData.recipient_account_id).to.eql(Number(pm.environment.get(\"recipientAccountId\")));\r",
                  "    pm.expect(jsonData.status).to.eql(\"pending\");\r",
                  "\r",
                  "    pm.environment.set(\"transactionId\", jsonData.id);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"senderAccountId\": 1 ,\r\n  \"recipientAccountId\": 2,\r\n  \"amount\": 500\r\n}\r\n",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:4000/transactions/transfer",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "4000",
              "path": [
                "transactions",
                "transfer"
              ]
            }
          },
          "response": []
        },
