    {
      "name": "06-Performance/Edge",
      "item": [
        {
          "name": "GET/Rate-Limiting",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"TC13 - Status should be 429 if rate limiting is implemented\", function () {\r",
                  "    pm.expect([200, 429]).to.include(pm.response.code);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"TC13 - Response time is below 5 seconds\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(5000);\r",
                  "});\r",
                  "\r",
                  "if (pm.response.code === 200) {\r",
                  "    console.log(\"DEFECT: Rate limiting is not implemented. API continues accepting repeated requests.\");\r",
                  "}\r",
                  "\r",
                  "if (pm.response.code === 429) {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    pm.test(\"TC13 - Rate limit message returned\", function () {\r",
                  "        pm.expect(jsonData).to.have.property(\"message\");\r",
                  "    });\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions/history",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions",
                "history"
              ]
            }
          },
          "response": []
        },
