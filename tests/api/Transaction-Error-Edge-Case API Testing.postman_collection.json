        {
          "name": "POST-boundary-transfer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"BTC05 - Status code is 201 or 400 depending on balance\", function () {\r",
                  "    pm.expect([201, 400]).to.include(pm.response.code);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"BTC05 - AML rule is handled correctly\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "\r",
                  "    if (pm.response.code === 201) {\r",
                  "        pm.expect(jsonData.status).to.eql(\"rejected\");\r",
                  "        pm.expect(jsonData.compliance_flag).to.eql(\"aml\");\r",
                  "    }\r",
                  "\r",
                  "    if (pm.response.code === 400) {\r",
                  "        pm.expect(jsonData).to.have.property(\"message\");\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
