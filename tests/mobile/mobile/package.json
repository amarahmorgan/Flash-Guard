{
  "name": "flashguard-mobile-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "e2e:typecheck": "tsc -p e2e/tsconfig.json --noEmit",
    "mobile:bddgen": "bddgen -c e2e/playwright.mobile-bdd.config.ts",
    "test:mobile:bdd": "npm run mobile:bddgen && playwright test --config=e2e/playwright.mobile-bdd.config.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-face-detector": "^13.0.2",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "private": true,
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.61.0",
    "@types/react": "~19.1.10",
    "playwright-bdd": "^9.2.0",
    "typescript": "^5.9.3",
    "webdriverio": "^9.29.0"
  }
}
