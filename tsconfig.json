{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "node",
      "@playwright/test"
    ]
  },
  "include": [
    "playwright.config.ts",
    "src/**/*.ts",
    "tests/ui/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".features-gen",
    "playwright-report",
    "test-results",
    "reports",
    "tests/mobile/**",
    "tests/e2e/**"
  ]
}